# ============================================
# Airtable CLI Authentication Configuration
# ============================================

# Option 1: OAuth (Recommended for distribution)
# Register at: https://airtable.com/create/oauth
# Then run: airtable auth login
AIRTABLE_CLIENT_ID=your_oauth_client_id
AIRTABLE_CLIENT_SECRET=your_oauth_client_secret

# Option 2: Personal Access Token (Simpler for personal use)
# Get yours at: https://airtable.com/create/tokens
# AIRTABLE_API_KEY=pat.xxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth callback port (default: 4000)
# AIRTABLE_OAUTH_PORT=4000

# OAuth scopes (space-separated, defaults shown)
# AIRTABLE_SCOPES=data.records:read data.records:write schema.bases:read schema.bases:write webhook:manage
